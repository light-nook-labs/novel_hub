SECRET_KEY=change-me-to-a-random-string
DEBUG=1

# SQLite (development - default)
DB_TYPE=sqlite

# PostgreSQL (uncomment to use)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=novel_hub
# DB_USER=postgres
# DB_PASSWORD=

# ALLOWED_HOSTS (comma-separated, required for production)
# ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1
